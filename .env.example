# ── LLM Provider ──────────────────────────────────────────────────────────
# We use Anthropic's API surface via a compatible proxy.
# Replace these with your own keys when deploying for real.
ANTHROPIC_API_KEY=sk-ant-xxx-replace-me
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Default model name. Atlas Mercator uses:
#   - claude-sonnet-4-6  for the Orchestrator (quality)
#   - claude-haiku-4-5   for tools like translate / keyword (cost)
ATLAS_MODEL_DEFAULT=claude-sonnet-4-6
ATLAS_MODEL_FAST=claude-haiku-4-5

# ── Runtime ────────────────────────────────────────────────────────────────
ATLAS_LOG_LEVEL=INFO
ATLAS_LANG=zh-CN  # default UI language hint

# ── RAG ────────────────────────────────────────────────────────────────────
ATLAS_CHROMA_DIR=./.chroma
ATLAS_EMBED_MODEL=all-MiniLM-L6-v2
ATLAS_KB_TOP_K=3
# Backend: auto | sentence-transformers | tfidf
# Use 'tfidf' to skip HuggingFace downloads (offline / restricted networks).
ATLAS_RAG_BACKEND=tfidf
